@inherits LayoutComponentBase
@inject AuthStateProvider AuthState
@inject SearchService Search
@inject NoteActionsService NoteActions
@inject ThemeService Theme
@inject ApiService Api
@inject IJSRuntime JS
@implements IDisposable

<MudThemeProvider Theme="_theme" IsDarkMode="@Theme.IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider MaxWidth="MaxWidth.Small" FullWidth="true" />
<MudSnackbarProvider />

@if (AuthState.CurrentUser is not null)
{
    <MudLayout>
        <MudAppBar Elevation="0" Class="nodi-appbar">
            <button class="appbar-icon-btn" @onclick="() => _drawerOpen = !_drawerOpen"
                    title="Toggle sidebar">
                <Blazicon Svg="Lucide.PanelLeft" />
            </button>
            <MudTextField ShrinkLabel T="string"
                          Value="@searchTerm"
                          Placeholder="Search notes..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Immediate="true"
                          ValueChanged="@((string s) => OnSearch(s))"
                          Class="search-field px-3"/>

            <div class="appbar-right">
                <MudTooltip Text="New note">
                    <MudIconButton Icon="@Icons.Material.Filled.Add"
                                   OnClick="() => NoteActions.ExpandEditor()"
                                   Class="appbar-action-btn" />
                </MudTooltip>
                <UserMenu />
            </div>
        </MudAppBar>

        <MudDrawer @bind-Open="_drawerOpen" Variant="DrawerVariant.Responsive"
                   Elevation="0" Width="240px" Class="nodi-drawer">
            <NavMenu />
        </MudDrawer>

        <MudMainContent>
            <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-8">
                @Body
            </MudContainer>
        </MudMainContent>
    </MudLayout>
}
else
{
    @Body
}

@code {
    private bool _drawerOpen = true;
    private bool _themeLoaded = false;

    private string searchTerm = string.Empty;
    private void OnSearch(string value)
    {
        searchTerm = value;
        Search.Search(string.IsNullOrWhiteSpace(value) ? null : value);
    }

    protected override void OnInitialized()
    {
        Theme.OnThemeChanged += HandleThemeChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && AuthState.CurrentUser is null)
        {
            await AuthState.TryRestoreFromStorageAsync();
            StateHasChanged();
        }

        if (!_themeLoaded && AuthState.CurrentUser is not null)
        {
            _themeLoaded = true;
            var settings = await Api.GetUserSettingsAsync();
            Theme.Apply(settings?.Theme != "Light");
            await JS.InvokeVoidAsync("nodi.setTheme", Theme.IsDarkMode);
            StateHasChanged();
        }
    }

    private async void HandleThemeChanged()
    {
        await JS.InvokeVoidAsync("nodi.setTheme", Theme.IsDarkMode);
        StateHasChanged();
    }

    public void Dispose()
    {
        Theme.OnThemeChanged -= HandleThemeChanged;
    }

    private readonly MudTheme _theme = new()
    {
        Typography = new Typography()
        {
            Default = new()
            {
                FontFamily = new[] { "Syne", "sans-serif" }
            },

            H6 = new()
            {
                FontFamily = new[] { "Syne", "sans-serif" },
                FontWeight = 700,
                FontSize = "1.05rem",
                LineHeight = 1.4,
                LetterSpacing = "0.2px"
            },

            Subtitle1 = new()
            {
                FontFamily = new[] { "Syne", "sans-serif" },
                FontWeight = 600,
                FontSize = "1rem",
                LineHeight = 1.4,
                LetterSpacing = "0.2px"
            }
        },

        // ── Dark palette ───────────────────────────────────────────────────────
        PaletteDark = new PaletteDark()
        {
            Primary          = "#ff2d78",   // cyberpink
            Secondary        = "#00f5ff",   // neon cyan
            Background       = "#08000f",   // near-black deep purple
            Surface          = "#1a0030",   // dark violet surface
            DrawerBackground = "#0d0018",
            AppbarBackground = "#0d0018",
            AppbarText       = "#f0e6ff",
            DrawerText       = "#9b85b0",
            TextPrimary      = "#f0e6ff",
            TextSecondary    = "#9b85b0",
            ActionDefault    = "#9b85b0",
            Divider          = "rgba(255,45,120,0.15)",
        },

        // ── Light palette ──────────────────────────────────────────────────────
        PaletteLight = new PaletteLight()
        {
            Primary          = "#d6006a",   // deep cyberpink
            Secondary        = "#008fa3",   // muted cyan
            Background       = "#fdf0f6",   // soft pinkish white
            Surface          = "#ffffff",
            DrawerBackground = "#fce8f3",
            AppbarBackground = "#fff5fb",
            AppbarText       = "#1a0020",
            DrawerText       = "#6b4068",
            TextPrimary      = "#1a0020",
            TextSecondary    = "#6b4068",
            ActionDefault    = "#b090a8",
            Divider          = "rgba(214,0,106,0.15)",
        }
    };
}
