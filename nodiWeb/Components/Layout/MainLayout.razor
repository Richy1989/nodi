@inherits LayoutComponentBase
@inject AuthStateProvider AuthState
@inject SearchService Search
@inject NoteActionsService NoteActions

<MudThemeProvider Theme="_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider MaxWidth="MaxWidth.Small" FullWidth="true" />
<MudSnackbarProvider />

@if (AuthState.CurrentUser is not null)
{
    <MudLayout>
        <MudAppBar Elevation="0"
                   Style="border-bottom:1px solid rgba(255,255,255,.06);">
            <button class="appbar-icon-btn" @onclick="() => _drawerOpen = !_drawerOpen"
                    title="Toggle sidebar">
                <Blazicon Svg="Lucide.PanelLeft" />
            </button>
            <MudTextField ShrinkLabel T="string"
                          Value="@searchTerm"
                          Placeholder="Search notes..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Immediate="true"
                          ValueChanged="@((string s) => OnSearch(s))"
                          Class="search-field px-3"/>
            
            <div class="appbar-right">
                <MudTooltip Text="New note">
                    <MudIconButton Icon="@Icons.Material.Filled.Add"
                                   OnClick="() => NoteActions.ExpandEditor()"
                                   Class="appbar-action-btn" />
                </MudTooltip>
                <UserMenu />
            </div>
        </MudAppBar>

        <MudDrawer @bind-Open="_drawerOpen" Variant="DrawerVariant.Responsive"
                   Elevation="0" Width="240px"
                   Style="border-right:1px solid rgba(255,255,255,.06);">
            <NavMenu />
        </MudDrawer>

        <MudMainContent>
            <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-8">
                @Body
            </MudContainer>
        </MudMainContent>
    </MudLayout>
}
else
{
    @Body
}

@code {
    private bool _drawerOpen = true;
    
    private string searchTerm = string.Empty;
    private void OnSearch(string value)
    {
        searchTerm = value;
        Search.Search(string.IsNullOrWhiteSpace(value) ? null : value);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && AuthState.CurrentUser is null)
        {
            await AuthState.TryRestoreFromStorageAsync();
            StateHasChanged();
        }
    }

    private readonly MudTheme _theme = new()
    {
        Typography = new Typography()
        {
            Default = new()
            {
                FontFamily = new[] { "Roboto", "Segoe UI", "sans-serif" }
            },

            H6 = new()
            {
                FontFamily = new[] { "Roboto", "Segoe UI", "sans-serif" },
                FontWeight = 500,
                FontSize = "1.05rem",
                LineHeight = 1.4,
                LetterSpacing = "0.1px"
            },

            Subtitle1 = new()
            {
                FontFamily = new[] { "Roboto", "Segoe UI", "sans-serif" },
                FontWeight = 500,
                FontSize = "1rem",
                LineHeight = 1.4,
                LetterSpacing = "0.1px"
            }
        },
        PaletteDark = new PaletteDark()
        {
            Primary          = "#fbbf24",   // amber-400
            Secondary        = "#34d399",   // emerald-400
            Background       = "#18181b",   // zinc-900
            Surface          = "#27272a",   // zinc-800
            DrawerBackground = "#111115",
            AppbarBackground = "#111115",
            AppbarText       = "#f4f4f5",
            DrawerText       = "#d4d4d8",
            TextPrimary      = "#f4f4f5",
            TextSecondary    = "#a1a1aa",
            ActionDefault    = "#a1a1aa",
            Divider          = "rgba(255,255,255,0.07)",
        }
    };
}
