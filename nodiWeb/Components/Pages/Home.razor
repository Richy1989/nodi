@page "/"
@attribute [Authorize]                                          @* Redirect to /login if not authenticated *@
@rendermode @(new InteractiveServerRenderMode(prerender: false))@* Blazor Server, prerender off to avoid double-init *@
@inject ApiService Api
@inject IDialogService DialogService
@inject SearchService Search
@inject NoteActionsService NoteActions
@inject IJSRuntime JS
@implements IDisposable                                         @* Needed to unsubscribe from events on teardown *@

<PageTitle>Notes - nodi</PageTitle>

@* ── Inline note composer ─────────────────────────────────────────────────── *@
@* Toggles between a collapsed "Write a note..." bar and an expanded form *@

@if (_expanded)
{
    <div class="composer">
        <input class="composer-title" placeholder="Title"
               @bind="_newTitle" @bind:event="oninput" />

        <textarea class="composer-content" placeholder="Take a note..."
                  @bind="_newContent" @bind:event="oninput" rows="3"></textarea>

        @* Checklist items — only shown when at least one item has been added *@
        @if (_newItems.Count > 0)
        {
            <div class="composer-items">
                @for (int i = 0; i < _newItems.Count; i++)
                {
                    var idx = i;
                    <div class="composer-item-row">
                        <input type="checkbox" class="composer-checkbox"
                               checked="@_newItems[idx].IsChecked"
                               @onchange="e => _newItems[idx].IsChecked = (bool)(e.Value ?? false)" />
                        @* id="new-item-{idx}" lets OnAfterRenderAsync focus the right input after Enter *@
                        <input id="new-item-@idx" class="composer-item-text" placeholder="List item"
                               @bind="_newItems[idx].Text" @bind:event="oninput"
                               @onkeydown="e => HandleNewItemKeyDown(e, idx)" />
                        <button class="composer-remove-btn" @onclick="() => _newItems.RemoveAt(idx)">
                            <MudIcon Icon="@Icons.Material.Filled.Close" Style="font-size:16px;" />
                        </button>
                    </div>
                }
            </div>
        }

        <div class="composer-footer">
            @* Color picker — dots styled per note-color-{name} CSS classes *@
            <div class="composer-colors">
                @foreach (var color in _colors)
                {
                    <div class="color-dot note-color-@color.ToLower() @(_newColor == color ? "color-selected" : "")"
                         @onclick="() => _newColor = color"></div>
                }
            </div>
            <div class="composer-footer-actions">
                <button class="composer-add-item-btn" @onclick="() => _newItems.Add(new() { Order = _newItems.Count })">
                    <MudIcon Icon="@Icons.Material.Outlined.CheckBox" Style="font-size:18px;" />
                    Add item
                </button>
                <button class="composer-close-btn" @onclick="CancelInline">Close</button>
                <button class="composer-save-btn" @onclick="SaveInline">Save</button>
            </div>
        </div>
    </div>
}
else
{
    @* Collapsed state — clicking anywhere expands the composer *@
    @* stopPropagation on the actions div prevents the button click from also firing the parent onclick *@
    <div class="quick-add" @onclick="ExpandEditor">
        <span class="quick-add-placeholder">Write a note...</span>
        <div class="quick-add-actions" @onclick:stopPropagation="true">
            <button class="quick-add-btn" title="New note" @onclick="ExpandEditor">
                <MudIcon Icon="@Icons.Material.Outlined.Edit" Style="font-size:20px;" />
            </button>
        </div>
    </div>
}

@* ── Notes grid ───────────────────────────────────────────────────────────── *@

@if (loading)
{
    <div class="d-flex justify-center pa-8">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    </div>
}
else if (allNotes.Count == 0)
{
    <div class="d-flex flex-column align-center pa-16" style="opacity:.5;">
        <MudIcon Icon="@Icons.Material.Outlined.NoteAdd" Style="font-size:4rem;" Class="mb-3" />
        <MudText Typo="Typo.body1">No notes yet. Create your first note above!</MudText>
    </div>
}
else
{
    @* Pinned notes render in their own masonry grid above a divider *@
    @if (pinnedNotes.Count > 0)
    {
        <MudText Typo="Typo.overline" Color="Color.Secondary" Class="mb-2">Pinned</MudText>
        <div class="notes-masonry mb-4">
            @foreach (var note in pinnedNotes)
            {
                <div class="notes-masonry-item">
                    <NoteCard Note="note" OnClick="EditNote" OnPin="TogglePin"
                              OnArchive="ArchiveNote" OnDelete="DeleteNote" />
                </div>
            }
        </div>
        <MudDivider Class="mb-4" />
        <MudText Typo="Typo.overline" Color="Color.Secondary" Class="mb-2">Others</MudText>
    }

    <div class="notes-masonry">
        @foreach (var note in unpinnedNotes)
        {
            <div class="notes-masonry-item">
                <NoteCard Note="note" OnClick="EditNote" OnPin="TogglePin"
                          OnArchive="ArchiveNote" OnDelete="DeleteNote" />
            </div>
        }
    </div>
}

@code {
    private List<NoteDto> allNotes     = [];
    private List<NoteDto> pinnedNotes  = [];
    private List<NoteDto> unpinnedNotes = [];
    private string? currentSearch;
    private bool loading = true;

    // ── Inline composer state ──────────────────────────────────────────────
    private bool    _expanded  = false;
    private string  _newTitle  = string.Empty;
    private string? _newContent;
    private string  _newColor  = "Default";
    private List<ItemModel> _newItems = [];
    // -1 means no pending focus; set to an item index to focus that input after the next render
    private int _focusItemIdx = -1;

    private static readonly string[] _colors =
        ["Default", "Salmon", "Peach", "LightYellow", "Mint", "Cyan",
         "SkyBlue", "CornflowerBlue", "Lavender", "HotPink", "Tan", "Silver"];

    private class ItemModel
    {
        public string Text      { get; set; } = string.Empty;
        public bool   IsChecked { get; set; }
        public int    Order     { get; set; }
    }

    // ── Lifecycle ──────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        // Subscribe to cross-component events
        Search.OnSearch            += HandleSearch;
        NoteActions.OnExpandEditor += HandleExpandEditor;
        await LoadNotes();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // JSDisconnectedException is caught here because the SignalR circuit can drop
        // momentarily (e.g. tab move, network hiccup) while a render is in flight.
        // Without the catch the exception would propagate and crash the server process.
        try
        {
            // Focus the newly inserted checklist item if Enter was pressed
            if (_focusItemIdx >= 0)
            {
                await JS.InvokeVoidAsync("nodi.focusById", $"new-item-{_focusItemIdx}");
                _focusItemIdx = -1;
            }
            // Re-init masonry layout after every render that has notes visible
            if (!loading && allNotes.Count > 0)
                await JS.InvokeVoidAsync("masonry.init", ".notes-masonry");
        }
        catch (JSDisconnectedException) { }
    }

    public void Dispose()
    {
        // Unsubscribe to prevent memory leaks and stale callbacks after the circuit closes
        Search.OnSearch            -= HandleSearch;
        NoteActions.OnExpandEditor -= HandleExpandEditor;
    }

    // ── Search ─────────────────────────────────────────────────────────────

    // async void is required by the event delegate signature.
    // All exceptions must be caught internally — an unhandled exception in async void
    // bypasses the ASP.NET Core pipeline and crashes the server process with exit code -1.
    private async void HandleSearch(string? term)
    {
        try
        {
            currentSearch = term;
            await LoadNotes(term);
            StateHasChanged();
        }
        catch (ObjectDisposedException) { } // Circuit was disposed before the await completed
        catch (Exception) { }
    }

    private async Task LoadNotes(string? search = null)
    {
        loading       = true;
        allNotes      = await Api.GetNotesAsync(search: search);
        pinnedNotes   = allNotes.Where(n => n.IsPinned).ToList();
        unpinnedNotes = allNotes.Where(n => !n.IsPinned).ToList();
        loading       = false;
    }

    // ── Inline composer ────────────────────────────────────────────────────

    // Called from NoteActionsService (e.g. toolbar button) — needs StateHasChanged
    // because the call comes from outside the Blazor render cycle
    private void HandleExpandEditor()
    {
        ExpandEditor();
        StateHasChanged();
    }

    private void ExpandEditor()
    {
        _expanded   = true;
        _newTitle   = string.Empty;
        _newContent = null;
        _newColor   = "Default";
        _newItems   = [];
    }

    // Enter on a checklist item inserts a new item below it and queues focus on it
    private void HandleNewItemKeyDown(KeyboardEventArgs e, int idx)
    {
        if (e.Key != "Enter") return;
        _newItems.Insert(idx + 1, new() { Order = idx + 1 });
        // Rewrite Order to keep indices contiguous
        for (int i = 0; i < _newItems.Count; i++) _newItems[i].Order = i;
        _focusItemIdx = idx + 1;
    }

    private void CancelInline() => _expanded = false;

    private async Task SaveInline()
    {
        var hasContent = !string.IsNullOrWhiteSpace(_newTitle)
                      || !string.IsNullOrWhiteSpace(_newContent)
                      || _newItems.Count > 0;

        if (hasContent)
        {
            var type = _newItems.Count > 0 ? "Checklist" : "Text";
            await Api.CreateNoteAsync(new
            {
                title          = _newTitle,
                content        = _newContent,
                color          = _newColor,
                type,
                checklistItems = _newItems.Select((it, i) => new { it.Text, it.IsChecked, Order = i }).ToList()
            });
            await LoadNotes();
        }

        _expanded = false;
    }

    // ── Edit existing note (dialog) ────────────────────────────────────────

    // Opens NoteEditor as a MudBlazor dialog, passing the note as a parameter.
    // Waits for the dialog to close, then processes the save if not cancelled.
    private async Task EditNote(NoteDto note)
    {
        var parameters = new DialogParameters<NoteEditor> { { x => x.ExistingNote, note } };
        var dialog = await DialogService.ShowAsync<NoteEditor>("Edit Note", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: SaveNoteArgs args })
            await ProcessSave(note, args);
    }

    private async Task ProcessSave(NoteDto existing, SaveNoteArgs args)
    {
        // Don't save if the note is now empty
        if (string.IsNullOrWhiteSpace(args.Title) && string.IsNullOrWhiteSpace(args.Content) && args.Items.Count == 0)
            return;

        await Api.UpdateNoteAsync(existing.Id, new
        {
            title          = args.Title,
            content        = args.Content,
            color          = args.Color,
            checklistItems = args.Items.Select(i => new { i.Text, i.IsChecked, i.Order }).ToList()
        });

        await LoadNotes();
    }

    // ── Note actions ───────────────────────────────────────────────────────

    private async Task TogglePin(NoteDto note)
    {
        await Api.UpdateNoteAsync(note.Id, new { isPinned = !note.IsPinned });
        await LoadNotes();
    }

    private async Task ArchiveNote(NoteDto note)
    {
        await Api.UpdateNoteAsync(note.Id, new { isArchived = true });
        await LoadNotes();
    }

    private async Task DeleteNote(NoteDto note)
    {
        await Api.DeleteNoteAsync(note.Id);
        await LoadNotes();
    }
}
