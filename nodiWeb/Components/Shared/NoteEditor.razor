@* Dialog component for editing an existing note.
   Opened by Home.razor via IDialogService; returns a SaveNoteArgs on save. *@
@inject IJSRuntime JS

<MudDialog>
    <TitleContent>
        <MudTextField @bind-Value="editNote.Title" Placeholder="Title"
                      Variant="Variant.Text" Typo="Typo.h6"
                      DisableUnderLine="true" Style="font-weight:600; font-size:1.1rem;" />
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="editNote.Content" Placeholder="Take a note..."
                      Variant="Variant.Text" Lines="4" AutoGrow="true"
                      DisableUnderLine="true" FullWidth="true" Class="mb-2" />

        @* Checklist items — divider only shown when there are items *@
        @if (items.Count > 0)
        {
            <MudDivider Class="mb-2" />
        }

        @for (int i = 0; i < items.Count; i++)
        {
            var idx = i;
            <div class="d-flex align-center gap-2 mb-1">
                <MudCheckBox T="bool" Value="@items[idx].IsChecked"
                             ValueChanged="@((bool v) => items[idx].IsChecked = v)"
                             Size="Size.Small" Color="Color.Primary" />
                @* Plain <input> used (not MudTextField) so we can set id directly on the element
                   for JS focus after Enter. id="edit-item-{idx}" matches nodi.focusById calls. *@
                <input id="edit-item-@idx" class="composer-item-text" placeholder="List item"
                       @bind="items[idx].Text" @bind:event="oninput"
                       @onkeydown="e => HandleItemKeyDown(e, idx)" />
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                               OnClick="() => RemoveItem(idx)" />
            </div>
        }

        <MudButton StartIcon="@Icons.Material.Filled.Add" Size="Size.Small"
                   Variant="Variant.Text" OnClick="AddItem" Class="mb-2">Add item</MudButton>

        <MudDivider Class="my-3" />

        @* Color picker — dots styled per note-color-{name} CSS classes in app.css *@
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">Color</MudText>
        <div class="d-flex flex-wrap gap-2" style="padding-bottom:5px;">
            @foreach (var color in Colors)
            {
                <div class="color-dot note-color-@color.ToLower() @(editNote.Color == color ? "color-selected" : "")"
                     title="@color" @onclick="() => editNote.Color = color"></div>
            }
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Close</MudButton>
        <MudButton OnClick="Save" Variant="Variant.Filled" Color="Color.Primary">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public NoteDto? ExistingNote { get; set; }

    private static readonly string[] Colors = ["Default", "Salmon", "Peach", "LightYellow", "Mint", "Cyan", "SkyBlue", "CornflowerBlue", "Lavender", "HotPink", "Tan", "Silver"];
    private EditModel editNote = new();
    private List<ItemModel> items = [];
    // -1 means no pending focus; set to an item index to focus that input after the next render
    private int _focusItemIdx = -1;

    // Runs every time the dialog is opened or ExistingNote changes
    protected override void OnParametersSet()
    {
        if (ExistingNote is not null)
        {
            editNote = new EditModel
            {
                Title   = ExistingNote.Title,
                Content = ExistingNote.Content,
                Color   = ExistingNote.Color,
            };
            items = ExistingNote.ChecklistItems
                .Select(i => new ItemModel { Text = i.Text, IsChecked = i.IsChecked, Order = i.Order })
                .ToList();
        }
        else
        {
            editNote = new EditModel();
            items = [];
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // JSDisconnectedException can occur if the SignalR circuit drops mid-render.
        // Catching it here prevents the exception from crashing the server process.
        try
        {
            if (_focusItemIdx >= 0)
            {
                await JS.InvokeVoidAsync("nodi.focusById", $"edit-item-{_focusItemIdx}");
                _focusItemIdx = -1;
            }
        }
        catch (JSDisconnectedException) { }
    }

    // Enter on a checklist item inserts a new item below it and queues focus on it
    private void HandleItemKeyDown(KeyboardEventArgs e, int idx)
    {
        if (e.Key != "Enter") return;
        items.Insert(idx + 1, new ItemModel { Order = idx + 1 });
        // Rewrite Order to keep indices contiguous
        for (int i = 0; i < items.Count; i++) items[i].Order = i;
        _focusItemIdx = idx + 1;
    }

    private void AddItem() => items.Add(new ItemModel { Order = items.Count });
    private void RemoveItem(int idx) => items.RemoveAt(idx);
    private void Cancel() => MudDialog.Cancel();

    // Closes the dialog and passes the edited data back to Home.razor via SaveNoteArgs
    private void Save()
    {
        var type = items.Count > 0 ? "Checklist" : "Text";
        MudDialog.Close(new SaveNoteArgs(
            editNote.Title,
            editNote.Content,
            editNote.Color,
            type,
            items.Select((it, i) => new NoteItemArg(it.Text, it.IsChecked, i)).ToList()
        ));
    }

    private class EditModel
    {
        public string  Title   { get; set; } = string.Empty;
        public string? Content { get; set; }
        public string  Color   { get; set; } = "Default";
    }

    private class ItemModel
    {
        public string Text      { get; set; } = string.Empty;
        public bool   IsChecked { get; set; }
        public int    Order     { get; set; }
    }
}
