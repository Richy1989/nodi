# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real secrets.

# ── Ports ─────────────────────────────────────────────────────────────────────
# Host and container ports for each service (must match — both sides use the same value)
CORE_PORT=5100
WEB_PORT=8080

# ── Secrets ───────────────────────────────────────────────────────────────────
# A long random secret used to sign JWT tokens (min 32 characters)
JWT_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS

# Initial admin account (only used on first run when the DB is empty)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@nodi.local
ADMIN_PASSWORD=CHANGE_THIS_PASSWORD
