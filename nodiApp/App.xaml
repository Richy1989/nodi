<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:nodiApp"
             xmlns:conv="clr-namespace:nodiApp.Converters"
             x:Class="nodiApp.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <conv:IsNotNullConverter x:Key="IsNotNullConverter"/>
            <conv:IsNotEmptyConverter x:Key="IsNotEmptyConverter"/>
            <conv:InvertBoolConverter x:Key="InvertBoolConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
